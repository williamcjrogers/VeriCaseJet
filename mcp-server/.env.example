# VeriCase API Configuration
VERICASE_API_URL=http://localhost:8010
VERICASE_JWT_TOKEN=your_jwt_token_here
VERICASE_API_KEY=optional_api_key

# Authentication (alternative to JWT)
VERICASE_USERNAME=your_username
VERICASE_PASSWORD=your_password

# Request Configuration
REQUEST_TIMEOUT=30
MAX_RETRIES=3

# Feature Flags
ENABLE_AI_TOOLS=true
ENABLE_PST_TOOLS=true

# Logging
LOG_LEVEL=INFO
